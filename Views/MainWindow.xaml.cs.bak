using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.IO.Ports;
using System.Threading.Tasks;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Input;
using System.Windows.Media;
using System.Windows.Threading;
using HamDeck.Models;
using HamDeck.Services;

namespace HamDeck.Views;

public partial class MainWindow : Window
{
    private readonly Config _config;
    private readonly RadioController _radio;
    private readonly AudioRecorder _recorder;
    private readonly AmpTuner _ampTuner;
    private readonly TGXLTuner _tgxlTuner;
    private readonly WavelogService _wavelog;
    private readonly ApiServer _apiServer;
    private readonly DXClusterService _dxCluster;
    private readonly KmtronicService _kmtronic;
    
    private readonly DispatcherTimer _updateTimer;
    private readonly Dictionary<string, long> _bandMemory;
    private string _currentBand = "";
    
    // PTT Auto-record state
    private bool _lastPttState;
    private bool _autoRecordActive;
    private DateTime _autoRecordTimer;
    private long _autoRecordFreq;
    private bool _tuningInProgress;

    public MainWindow()
    {
        InitializeComponent();
        
        // Load config
        _config = Config.Load();
        
        // Initialize services
        _radio = new RadioController();
        _recorder = new AudioRecorder(_radio, _config);
        _ampTuner = new AmpTuner(_radio);
        _tgxlTuner = new TGXLTuner(_radio, _config);
        _wavelog = new WavelogService(_radio, _config);
        _dxCluster = new DXClusterService(_config.DxClusterUrl);
        _dxCluster.RefreshIntervalSeconds = _config.DxClusterRefreshSeconds;
        _kmtronic = new KmtronicService(_config.KmtronicHost, _config.KmtronicPort)
        {
            IsEnabled = _config.KmtronicEnabled
        };
        _apiServer = new ApiServer(_radio, _recorder, _ampTuner, _tgxlTuner, _config, _dxCluster, _kmtronic);
        
        // Initialize band memory
        _bandMemory = new Dictionary<string, long>
        {
            ["160"] = 1900000,
            ["80"] = 3885000,
            ["60"] = 5330500,
            ["40"] = 7200000,
            ["30"] = 10130000,
            ["20"] = 14250000,
            ["17"] = 18130000,
            ["15"] = 21300000,
            ["12"] = 24950000,
            ["10"] = 28400000,
            ["6"] = 50125000
        };
        
        // Setup COM port list
        PopulateComPorts();
        
        // Setup update timer
        _updateTimer = new DispatcherTimer
        {
            Interval = TimeSpan.FromMilliseconds(500)
        };
        _updateTimer.Tick += UpdateTimer_Tick;
        
        // Update API label
        ApiLabel.Text = $"API: :{_config.ApiPort}";
        
        // Auto-connect
        Loaded += async (s, e) =>
        {
            await Task.Delay(500);
            AutoConnect();
            
            // Start Wavelog integration
            _wavelog.Start();
            
            // Start API server
            _apiServer.Start();
            
            // Start buffer
            await Task.Delay(1000);
            _recorder.StartBuffer(_config.AudioDeviceIndex);
            
            // Start DX Cluster
            _dxCluster.SpotsUpdated += DxCluster_SpotsUpdated;
            _dxCluster.Error += DxCluster_Error;
            _dxCluster.Start();
        };
        
        // Handle close
        Closing += (s, e) =>
        {
            if (_config.MinimizeToTray)
            {
                e.Cancel = true;
                Hide();
                return;
            }
            Cleanup();
        };
        
        _updateTimer.Start();
    }

    private void PopulateComPorts()
    {
        PortCombo.Items.Clear();
        foreach (var port in SerialPort.GetPortNames())
        {
            PortCombo.Items.Add(port);
        }
        
        // Add common ports that might not be present
        for (int i = 1; i <= 16; i++)
        {
            var port = $"COM{i}";
            if (!PortCombo.Items.Contains(port))
                PortCombo.Items.Add(port);
        }
        
        PortCombo.SelectedItem = _config.RadioPort;
    }

    private void AutoConnect()
    {
        Console.WriteLine($"Auto-connecting to {_config.RadioPort} at {_config.RadioBaud} baud...");
        if (_radio.Connect(_config.RadioPort, _config.RadioBaud))
        {
            ConnStatus.Text = "â— Connected";
            ConnStatus.Foreground = (Brush)FindResource("GreenBrush");
            _recorder.ResetBuffer();
        }
    }

    private void ConnectBtn_Click(object sender, RoutedEventArgs e)
    {
        if (_radio.IsConnected)
        {
            _radio.Disconnect();
            ConnStatus.Text = "â— Disconnected";
            ConnStatus.Foreground = (Brush)FindResource("RedBrush");
        }
        else
        {
            var port = PortCombo.SelectedItem?.ToString() ?? _config.RadioPort;
            _config.RadioPort = port;
            _config.Save();
            
            if (_radio.Connect(port, _config.RadioBaud))
            {
                ConnStatus.Text = "â— Connected";
                ConnStatus.Foreground = (Brush)FindResource("GreenBrush");
                _recorder.ResetBuffer();
            }
        }
    }

    private void UpdateTimer_Tick(object? sender, EventArgs e)
    {
        if (!_radio.IsConnected)
        {
            return;
        }

        // Update frequency
        var freq = _radio.GetFreq();
        if (freq > 0)
        {
            var mhz = freq / 1000000;
            var khz = (freq % 1000000) / 1000;
            var hz = freq % 1000;
            FreqDisplay.Text = $"{mhz}.{khz:D3}.{hz:D3}";
        }

        if (!_radio.IsConnected)
        {
            ConnStatus.Text = "â— Radio off";
            ConnStatus.Foreground = (Brush)FindResource("RedBrush");
            return;
        }

        // Update mode/VFO
        ModeDisplay.Text = _radio.GetMode();
        VfoDisplay.Text = $"VFO-{_radio.GetVFO()}";

        // Get PTT state
        var pttActive = _radio.GetTXStatus();
        var tuningActive = _tuningInProgress || _ampTuner.IsActive || _tgxlTuner.IsActive;

        // PTT auto-record
        if (_config.PttRecordEnabled && pttActive && !_lastPttState && !tuningActive)
        {
            if (!_autoRecordActive)
            {
                Console.WriteLine("PTT Auto-Record: Starting");
                _recorder.Start();
                _autoRecordActive = true;
                _autoRecordFreq = freq;
                RecordBtn.Content = "â–  Stop";
                RecordStatus.Text = "Auto-recording (PTT)";
            }
            _autoRecordTimer = DateTime.Now.AddSeconds(_config.PttRecordSeconds);
        }
        _lastPttState = pttActive;

        // Auto-record timer/QSY check
        if (_autoRecordActive && _autoRecordTimer > DateTime.MinValue && !tuningActive)
        {
            // Extend timer if it's low and we're tuning
            if (tuningActive && (DateTime.Now - _autoRecordTimer).TotalSeconds < 10)
            {
                _autoRecordTimer = DateTime.Now.AddSeconds(_config.PttRecordSeconds);
            }
            
            if (DateTime.Now > _autoRecordTimer)
            {
                Console.WriteLine("PTT Auto-Record: Timer expired");
                StopPttRecording();
            }
            else if (_autoRecordFreq > 0)
            {
                var qsyThreshold = _config.PttQsyThresholdKhz * 1000;
                var freqDiff = Math.Abs(freq - _autoRecordFreq);
                if (freqDiff > qsyThreshold)
                {
                    Console.WriteLine($"PTT Auto-Record: QSY detected ({freqDiff / 1000.0:F1} kHz)");
                    StopPttRecording();
                }
            }
        }

        // Update S-meter/TX indicator
        if (pttActive)
        {
            TxIndicator.Foreground = (Brush)FindResource("RedBrush");
            var pwrMeter = _radio.GetPowerMeter();
            SMeterBar.Value = pwrMeter * 100.0 / 255.0;
            
            var swr = _radio.GetSWR();
            if (swr > 100)
            {
                SMeterLabel.Text = "TX SWR!";
            }
            else
            {
                var pwrWatts = pwrMeter * _radio.GetPower() / 255;
                SMeterLabel.Text = $"{pwrWatts}W";
            }
        }
        else
        {
            TxIndicator.Foreground = new SolidColorBrush(Color.FromRgb(80, 80, 80));
            var smeter = _radio.GetSMeter();
            SMeterBar.Value = smeter * 100.0 / 255.0;
            SMeterLabel.Text = RadioController.RawToSUnit(smeter);
        }

        // Update buffer status
        if (_recorder.IsBuffering)
        {
            var bufSecs = _recorder.GetBufferFillSeconds();
            BufferLabel.Text = $"Buffer: {bufSecs:F0}s/{_recorder.BufferSeconds}s";
            AudioLevelBar.Value = _recorder.AudioLevel;
        }
        else
        {
            BufferLabel.Text = "Buffer: OFF";
            AudioLevelBar.Value = 0;
        }

        // Update recording time
        if (_recorder.IsRecording)
        {
            var elapsed = _recorder.GetElapsed().TotalSeconds + _recorder.BufferSeconds;
            var mins = (int)elapsed / 60;
            var secs = (int)elapsed % 60;
            
            if (_autoRecordActive && _autoRecordTimer > DateTime.MinValue)
            {
                var remaining = (_autoRecordTimer - DateTime.Now).TotalSeconds;
                if (remaining > 0)
                {
                    var remMins = (int)remaining / 60;
                    var remSecs = (int)remaining % 60;
                    RecordTime.Text = $"{mins:D2}:{secs:D2} (-{remMins:D2}:{remSecs:D2})";
                }
                else
                {
                    RecordTime.Text = $"{mins:D2}:{secs:D2}";
                }
            }
            else
            {
                RecordTime.Text = $"{mins:D2}:{secs:D2}";
            }
        }
    }

    private void FreqEntry_KeyDown(object sender, KeyEventArgs e)
    {
        if (e.Key == Key.Enter)
        {
            FreqGo_Click(sender, e);
        }
    }

    private void FreqGo_Click(object sender, RoutedEventArgs e)
    {
        var text = FreqEntry.Text.Trim();
        if (string.IsNullOrEmpty(text)) return;
        
        var freq = ParseFrequency(text);
        if (freq > 0)
        {
            var mode = RadioController.GetModeForFrequency(freq);
            _radio.SetMode(mode);
            _radio.SetFreq(freq);
            FreqEntry.Text = "";
            Console.WriteLine($"Tuned to {freq} Hz ({mode})");
        }
    }

    private static long ParseFrequency(string input)
    {
        input = input.Trim().Replace(",", "");
        if (string.IsNullOrEmpty(input)) return 0;

        if (input.Contains('.'))
        {
            if (double.TryParse(input, out var f))
            {
                // Check if looks like MHz (< 100) or kHz
                var parts = input.Split('.');
                if (long.TryParse(parts[0], out var intPart))
                {
                    if (intPart < 100)
                        return (long)(f * 1000000); // MHz
                    else
                        return (long)(f * 1000); // kHz
                }
            }
        }
        else if (long.TryParse(input, out var val))
        {
            if (val < 100)
                return val * 1000000; // MHz shorthand
            else if (val < 100000)
                return val * 1000; // kHz
            else
                return val; // Hz
        }
        
        return 0;
    }

    private void Mode_Click(object sender, RoutedEventArgs e)
    {
        if (sender is Button btn && btn.Tag is string mode)
        {
            _radio.SetMode(mode);
        }
    }

    private void Band_Click(object sender, RoutedEventArgs e)
    {
        if (sender is Button btn && btn.Tag is string band)
        {
            SwitchBand(band);
        }
    }

    private void SwitchBand(string band)
    {
        // Save current frequency to current band
        if (!string.IsNullOrEmpty(_currentBand) && _radio.IsConnected)
        {
            var currentFreq = _radio.GetFreq();
            if (currentFreq > 0)
                _bandMemory[_currentBand] = currentFreq;
        }

        // Get frequency for new band
        var freq = _bandMemory.GetValueOrDefault(band, 14250000);
        
        // Set frequency and mode
        _radio.SetFreq(freq);
        _radio.SetMode(RadioController.GetModeForFrequency(freq));
        _currentBand = band;
        
        Console.WriteLine($"Band {band}: {freq / 1000000.0:F3} MHz");
    }

    private void PowerSlider_Changed(object sender, RoutedPropertyChangedEventArgs<double> e)
    {
        if (_radio == null || !_radio.IsConnected) return;
        
        var watts = (int)PowerSlider.Value;
        _radio.SetPower(watts);
        PowerLabel.Content = $"Power: {watts} W";
    }

    private void VfoSwap_Click(object sender, RoutedEventArgs e)
    {
        _radio.SwapVFO();
    }

    private void Split_Click(object sender, RoutedEventArgs e)
    {
        _radio.SetSplit(!_radio.GetSplit());
    }

    private async void Tgxl_Click(object sender, RoutedEventArgs e)
    {
        _tuningInProgress = true;
        try
        {
            await _tgxlTuner.TuneAsync();
        }
        finally
        {
            _tuningInProgress = false;
        }
    }

    private async void Amp_Click(object sender, RoutedEventArgs e)
    {
        _tuningInProgress = true;
        try
        {
            await _ampTuner.TuneAsync(30, 0.20);
        }
        finally
        {
            _tuningInProgress = false;
        }
    }

    private void Record_Click(object sender, RoutedEventArgs e)
    {
        if (_recorder.IsRecording)
        {
            StopRecording();
        }
        else
        {
            StartRecording();
        }
    }

    private void StartRecording()
    {
        _recorder.Start();
        RecordBtn.Content = "â–  Stop";
        RecordStatus.Text = $"Recording (+{_recorder.BufferSeconds}s buffer)...";
    }

    private void StopRecording()
    {
        RecordBtn.Content = "â— Record";
        RecordStatus.Text = "Saving...";
        
        _autoRecordActive = false;
        _autoRecordTimer = DateTime.MinValue;

        var filename = _recorder.Stop();
        
        RecordStatus.Text = "Saved!";
        RecordTime.Text = "";
        
        Task.Delay(3000).ContinueWith(_ => 
            Dispatcher.Invoke(() => RecordStatus.Text = ""));
    }

    private void StopPttRecording()
    {
        RecordBtn.Content = "â— Record";
        RecordStatus.Text = "Saving QSO...";
        
        _autoRecordActive = false;
        _autoRecordTimer = DateTime.MinValue;

        // Get PTT record path with date subfolders
        var pttBasePath = string.IsNullOrEmpty(_config.PttRecordPath) 
            ? Config.DefaultPttRecordPath 
            : _config.PttRecordPath;
        
        var now = DateTime.UtcNow;
        var monthFolder = now.ToString("yyyy-MM");
        var dateFolder = now.ToString("yyyy-MM-dd");
        var pttPath = Path.Combine(pttBasePath, monthFolder, dateFolder);

        var filename = _recorder.StopWithPath(pttPath, "qso");
        
        RecordStatus.Text = "QSO saved!";
        RecordTime.Text = "";
        
        Task.Delay(3000).ContinueWith(_ => 
            Dispatcher.Invoke(() => RecordStatus.Text = ""));
    }

    private void Replay_Click(object sender, RoutedEventArgs e)
    {
        RecordStatus.Text = "Saving replay...";
        var filename = _recorder.SaveReplay();
        RecordStatus.Text = filename != null ? "Replay saved!" : "Error";
        
        Task.Delay(3000).ContinueWith(_ => 
            Dispatcher.Invoke(() => RecordStatus.Text = ""));
    }

    private void Buffer_Changed(object sender, SelectionChangedEventArgs e)
    {
        if (_recorder == null) return;
        
        if (BufferCombo.SelectedItem is ComboBoxItem item)
        {
            var text = item.Content.ToString()?.Replace("s", "") ?? "60";
            if (int.TryParse(text, out var secs))
            {
                _recorder.SetBufferSize(secs);
                _recorder.StopBuffer();
                _recorder.StartBuffer(_config.AudioDeviceIndex);
            }
        }
    }

    private void OpenRecordings_Click(object sender, RoutedEventArgs e)
    {
        var recDir = string.IsNullOrEmpty(_config.RecordPath) 
            ? Config.DefaultRecordPath 
            : _config.RecordPath;
        
        Directory.CreateDirectory(recDir);
        Process.Start("explorer", recDir);
    }

    private void Settings_Click(object sender, RoutedEventArgs e)
    {
        var settingsWindow = new SettingsWindow(_config);
        settingsWindow.Owner = this;
        settingsWindow.ShowDialog();
    }

    #region DX Cluster
    
    private void DxCluster_SpotsUpdated(object? sender, List<DXSpot> spots)
    {
        Dispatcher.Invoke(() =>
        {
            DxSpotsList.ItemsSource = spots;
            DxSpotCount.Text = $"{spots.Count} spots";
            DxLastUpdate.Text = $"Updated: {DateTime.Now:HH:mm:ss}";
        });
    }
    
    private void DxCluster_Error(object? sender, string error)
    {
        Dispatcher.Invoke(() =>
        {
            DxLastUpdate.Text = $"Error: {error}";
        });
    }
    
    private void DxBandFilter_Changed(object sender, SelectionChangedEventArgs e)
    {
        if (_dxCluster == null) return;
        
        if (DxBandFilter.SelectedItem is ComboBoxItem item)
        {
            var band = item.Content.ToString();
            _dxCluster.BandFilter = band == "All" ? null : band;
            _ = _dxCluster.RefreshSpots();
        }
    }
    
    private void DxFilter_Changed(object sender, RoutedEventArgs e)
    {
        if (_dxCluster == null) return;
        
        _dxCluster.ShowPotaOnly = DxPotaFilter.IsChecked == true;
        _dxCluster.ShowLotwOnly = DxLotwFilter.IsChecked == true;
        _ = _dxCluster.RefreshSpots();
    }
    
    private async void DxRefresh_Click(object sender, RoutedEventArgs e)
    {
        DxRefreshBtn.IsEnabled = false;
        DxLastUpdate.Text = "Refreshing...";
        
        await _dxCluster.RefreshSpots();
        
        DxRefreshBtn.IsEnabled = true;
    }
    
    private void DxSpot_DoubleClick(object sender, System.Windows.Input.MouseButtonEventArgs e)
    {
        if (DxSpotsList.SelectedItem is DXSpot spot)
        {
            // QSY to the spot frequency
            var freq = spot.FrequencyHz;
            var mode = RadioController.GetModeForFrequency(freq);
            
            _radio.SetMode(mode);
            _radio.SetFreq(freq);
            
            Console.WriteLine($"QSY to {spot.Spotted} on {spot.FrequencyDisplay} kHz ({mode})");
        }
    }
    
    #endregion

    #region RX Antenna

    private void RxAnt_Click(object sender, RoutedEventArgs e)
    {
        if (sender is Button btn && int.TryParse(btn.Tag?.ToString(), out int ant))
        {
            _kmtronic.SetAntenna(ant);
            UpdateRxAntButtons(ant);
        }
    }

    /// <summary>Called by ApiServer when /api/rxant/N is hit from Stream Deck etc.</summary>
    public void SetRxAntenna(int ant)
    {
        _kmtronic.SetAntenna(ant);
        Dispatcher.Invoke(() => UpdateRxAntButtons(ant));
    }

    private void UpdateRxAntButtons(int active)
    {
        var activeColor = (Brush)FindResource("GreenBrush");
        var normalColor = (Brush)FindResource("ButtonBrush");

        RxAnt1Btn.Background = active == 1 ? activeColor : normalColor;
        RxAnt2Btn.Background = active == 2 ? activeColor : normalColor;
        RxAnt3Btn.Background = active == 3 ? activeColor : normalColor;
        RxAnt4Btn.Background = active == 4 ? activeColor : normalColor;
    }

    #endregion

    private void Cleanup()
    {
        _updateTimer.Stop();
        _dxCluster.Dispose();
        _apiServer.Dispose();
        _wavelog.Dispose();
        _recorder.Dispose();
        _radio.Dispose();
        _kmtronic.Dispose();
    }
}
